#!/bin/sh
#
# Installer for Rusty
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/PDG-Global/rusty/main/dist/install.sh | sh
#   curl -fsSL https://raw.githubusercontent.com/PDG-Global/rusty/main/dist/install.sh | sh -s -- --to ~/.cargo/bin
#
# Options:
#   --to DIR       Install directory (default: /usr/local/bin, or ~/.local/bin if not writable)
#   --version VER  Install a specific version (default: latest)
#   --skip-verify  Skip SHA256 checksum verification

set -euo pipefail

# ── Configuration ────────────────────────────────────────────────────────────

REPO="PDG-Global/rusty"
BINARY="rusty"
GITHUB="https://github.com/${REPO}"
RELEASES_URL="${GITHUB}/releases"

# ── Helpers ──────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { printf "${CYAN}>${NC} %s\n" "$*"; }
ok()    { printf "${GREEN}>${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}>${NC} %s\n" "$*"; }
err()   { printf "${RED}>${NC} %s\n" "$*" >&2; }
die()   { err "$@"; exit 1; }

need_cmd() {
    if ! command -v "$1" > /dev/null 2>&1; then
        die "Required command not found: $1"
    fi
}

# ── Detect platform ─────────────────────────────────────────────────────────

detect_os() {
    case "$(uname -s)" in
        Darwin)  echo "macos"    ;;
        Linux)   echo "linux"    ;;
        FreeBSD) echo "freebsd"  ;;
        MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
        *)       die "Unsupported OS: $(uname -s)" ;;
    esac
}

detect_arch() {
    case "$(uname -m)" in
        x86_64|amd64)   echo "x86_64"   ;;
        aarch64|arm64)   echo "aarch64"  ;;
        armv7*|armhf)    echo "armv7"    ;;
        *)               die "Unsupported architecture: $(uname -m)" ;;
    esac
}

# Map (os, arch) to the release binary name.
# Prefers static/musl on Linux to avoid glibc version issues.
select_binary() {
    local os="$1"
    local arch="$2"

    case "$os" in
        macos)
            echo "${BINARY}-macos-universal"
            ;;
        linux)
            case "$arch" in
                x86_64)  echo "${BINARY}-x86_64-linux-static" ;;
                aarch64) echo "${BINARY}-aarch64-linux-static" ;;
                armv7)   echo "${BINARY}-armv7-linux" ;;
                *)       die "No Linux binary for arch: $arch" ;;
            esac
            ;;
        freebsd)
            case "$arch" in
                x86_64)  echo "${BINARY}-x86_64-freebsd" ;;
                *)       die "No FreeBSD binary for arch: $arch" ;;
            esac
            ;;
        windows)
            case "$arch" in
                x86_64)  echo "${BINARY}-x86_64-pc-windows.exe" ;;
                *)       die "No Windows binary for arch: $arch" ;;
            esac
            ;;
    esac
}

# ── Resolve version ─────────────────────────────────────────────────────────

resolve_version() {
    local version="$1"
    if [ -n "$version" ]; then
        echo "$version"
        return
    fi

    # Fetch latest release tag from GitHub API
    need_cmd curl
    local tag
    tag=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" 2>/dev/null \
        | grep '"tag_name"' \
        | head -1 \
        | sed -E 's/.*"tag_name":\s*"v?([^"]+)".*/\1/') || true

    if [ -z "$tag" ]; then
        die "Could not determine latest version. Pass --version to specify manually."
    fi
    echo "$tag"
}

# ── Install ──────────────────────────────────────────────────────────────────

main() {
    local install_dir=""
    local version=""
    local skip_verify=false

    # Parse arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            --to)
                install_dir="$2"
                shift 2
                ;;
            --version)
                version="$2"
                shift 2
                ;;
            --skip-verify)
                skip_verify=true
                shift
                ;;
            -h|--help)
                echo "Usage: install.sh [--to DIR] [--version VER] [--skip-verify]"
                echo ""
                echo "Options:"
                echo "  --to DIR       Install directory (default: /usr/local/bin or ~/.local/bin)"
                echo "  --version VER  Install a specific version (default: latest)"
                echo "  --skip-verify  Skip SHA256 checksum verification"
                exit 0
                ;;
            *)
                die "Unknown option: $1"
                ;;
        esac
    done

    # Check prerequisites
    need_cmd uname
    need_cmd curl
    need_cmd mktemp
    if [ "$skip_verify" = false ]; then
        need_cmd sha256sum 2>/dev/null || need_cmd shasum 2>/dev/null || {
            warn "Neither sha256sum nor shasum found; skipping checksum verification"
            skip_verify=true
        }
    fi

    # Detect platform
    local os arch
    os=$(detect_os)
    arch=$(detect_arch)
    info "Platform: ${os}/${arch}"

    # Select binary
    local binary_name
    binary_name=$(select_binary "$os" "$arch")
    info "Binary: ${binary_name}"

    # Resolve version
    version=$(resolve_version "$version")
    info "Version: ${version}"

    # Build download URL
    local download_url="${RELEASES_URL}/download/v${version}/${binary_name}"
    local checksum_url="${download_url}.sha256"

    # Choose install directory
    if [ -z "$install_dir" ]; then
        if [ -d /usr/local/bin ] && [ -w /usr/local/bin ]; then
            install_dir="/usr/local/bin"
        elif [ -d /opt/homebrew/bin ] && [ -w /opt/homebrew/bin ]; then
            install_dir="/opt/homebrew/bin"
        else
            install_dir="${HOME}/.local/bin"
        fi
    fi
    mkdir -p "$install_dir"

    info "Install directory: ${install_dir}"

    # Download to temp directory
    local tmp_dir
    tmp_dir=$(mktemp -d)
    trap 'rm -rf "$tmp_dir"' EXIT

    local tmp_bin="${tmp_dir}/${binary_name}"
    info "Downloading ${download_url} ..."
    if ! curl -fsSL --progress-bar -o "$tmp_bin" "$download_url"; then
        die "Download failed. Check that version ${version} exists: ${RELEASES_URL}"
    fi
    ok "Downloaded"

    # Verify checksum
    if [ "$skip_verify" = false ]; then
        info "Verifying checksum..."
        local expected_hash
        if expected_hash=$(curl -fsSL "$checksum_url" 2>/dev/null | awk '{print $1}'); then
            local actual_hash
            if command -v sha256sum > /dev/null 2>&1; then
                actual_hash=$(sha256sum "$tmp_bin" | awk '{print $1}')
            else
                actual_hash=$(shasum -a 256 "$tmp_bin" | awk '{print $1}')
            fi
            if [ "$expected_hash" != "$actual_hash" ]; then
                die "Checksum mismatch!\n  Expected: ${expected_hash}\n  Got:      ${actual_hash}"
            fi
            ok "Checksum verified"
        else
            warn "Could not fetch checksum; skipping verification"
        fi
    fi

    # Install binary
    local dest="${install_dir}/${BINARY}"
    if [ "$os" = "windows" ]; then
        dest="${dest}.exe"
    fi

    info "Installing to ${dest} ..."
    cp "$tmp_bin" "$dest"
    chmod +x "$dest"
    ok "Installed"

    # Check if install dir is in PATH
    case ":${PATH}:" in
        *":${install_dir}:"*)
            ;;
        *)
            warn "${install_dir} is not in your PATH."
            echo ""
            echo "  Add it to your shell profile:"
            if [ -n "${ZSH_VERSION:-}" ] || [ -f "${HOME}/.zshrc" ]; then
                echo "    echo 'export PATH=\"${install_dir}:\$PATH\"' >> ~/.zshrc"
            fi
            if [ -n "${BASH_VERSION:-}" ] || [ -f "${HOME}/.bashrc" ]; then
                echo "    echo 'export PATH=\"${install_dir}:\$PATH\"' >> ~/.bashrc"
            fi
            echo ""
            ;;
    esac

    # Done
    echo ""
    ok "${BOLD}Rusty ${version}${NC} installed to ${dest}"
    echo ""
    echo "  Run 'rusty' to get started."
    echo "  Run 'rusty --setup' for first-time configuration."
}

main "$@"
